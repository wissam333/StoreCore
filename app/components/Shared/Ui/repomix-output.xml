                v-click-outside="() => (isThemePanelOpen = false)"
              >
                <div class="theme-panel-header">
                  <span>{{ $t("Theme") }}</span>
                  <button
                    class="theme-panel-close"
                    @click="isThemePanelOpen = false"
                  >
