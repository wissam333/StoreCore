                  <p class="theme-label">{{ $t("Mode") }}</p>
                  <div class="mode-toggle">
                    <button
                      class="mode-btn"
                      :class="{ active: !isDark }"
                      @click="() => isDark && toggleDark()"
                    >
                      <Icon name="mdi:white-balance-sunny" size="15" />
                      <span>{{ $t("Light") }}</span>
                    </button>
                    <button
                      class="mode-btn"
                      :class="{ active: isDark }"
                      @click="() => !isDark && toggleDark()"
                    >
