{
  "name": "storecore",
  "productName": "StoreCore",
  "version": "1.0.0",
  "description": "Offline-First Store Management System",
  "type": "module",
  "author": "Wissam Najjom",
  "main": "./main.js",
  "scripts": {
    "start": "electron-forge start",
    "build": "nuxt build && electron-forge make",
    "make": "cd .. && npx nuxt generate && xcopy /E /I /Y \".output\\public\" \"my-app\\public_nuxt\" && cd my-app && npx electron-forge make",
    "package": "nuxt build && electron-forge package",
    "publish": "electron-forge publish"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "electron": "39.2.4",
    "fs-extra": "^11.3.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-squirrel-startup": "^1.0.1",
    "node-machine-id": "^1.1.12"
  }
}
