<script setup>
// ── Theme ──────────────────────────────────────────────────────────────────────
const { init, primaryColor } = useTheme();
onMounted(() => init());

// ── Props ──────────────────────────────────────────────────────────────────────
defineProps({
  pageTitle: { type: String, default: "" },
  pageDescription: { type: String, default: "" },
  pageIcon: { type: String, default: "" },
  breadcrumbs: { type: Array, default: () => [] },
  showPageHeader: { type: Boolean, default: true },
});

// ── i18n / state ───────────────────────────────────────────────────────────────
const { locale } = useI18n();
const userInfo = useUserInfo();

// For a local-first desktop clinic we pull the logged-in staff from state
// (set during login page). Falls back to a sensible default.
const currentUser = computed(
  () => userInfo.value ?? { full_name: "Admin", role: "admin" },
);

const roleLabel = (role) => {
  const map = {
    admin: "Administrator",
    doctor: "Doctor",
    nurse: "Nurse",
    receptionist: "Receptionist",
  };
  return map[role] ?? role ?? "Staff";
};

const navbarUser = computed(() => ({
  name: currentUser.value?.full_name ?? "Admin",
  role: roleLabel(currentUser.value?.role),
  avatar: null,
  online: true,
}));

// ── Layout state ───────────────────────────────────────────────────────────────
const mobileSidebarOpen = ref(false);
const desktopCollapsed = ref(false);
const isMobile = ref(false);

// ── Logout ─────────────────────────────────────────────────────────────────────
const showLogoutModal = ref(false);
const isLoggingOut = ref(false);
const openLogoutConfirm = () => {
  showLogoutModal.value = true;
};

const handleLogout = async () => {
  isLoggingOut.value = true;
  try {
    localStorage.removeItem("userInfo");
    localStorage.removeItem("role");
    useAuth().value.isAuthenticated = false;
    useUserInfo().value = null;
    await navigateTo("/");
  } finally {
    isLoggingOut.value = false;
    showLogoutModal.value = false;
  }
};

const handleNavbarAction = () => {};
const handleUserClick = () => {};
const handleSearch = () => {};
const handleMenuItemClick = () => {};

// ── Clinic sidebar menu (static — no API needed) ───────────────────────────────
const menuItems = computed(() => [
  {
    key: "dashboard",
    label: "sidebar.dashboard",
    icon: "mdi:view-dashboard-outline",
    to: "/dashboard",
  },
  {
    key: "patients",
    label: "sidebar.patients",
    icon: "mdi:account-heart-outline",
    to: "/dashboard/patients",
  },
  {
    key: "visits",
    label: "sidebar.visits",
    icon: "mdi:stethoscope",
    children: [
      {
        key: "visits-today",
        label: "sidebar.todayVisits",
        icon: "mdi:calendar-today",
        to: "/dashboard/visits/today",
      },
      {
        key: "visits-all",
        label: "sidebar.allVisits",
        icon: "mdi:format-list-bulleted",
        to: "/dashboard/visits",
      },
      {
        key: "visits-new",
        label: "sidebar.newVisit",
        icon: "mdi:plus-circle-outline",
        to: "/dashboard/visits/new",
      },
    ],
  },
  {
    key: "appointments",
    label: "sidebar.appointments",
    icon: "mdi:calendar-clock-outline",
    to: "/dashboard/appointments",
  },
  {
    key: "prescriptions",
    label: "sidebar.prescriptions",
    icon: "mdi:pill",
    to: "/dashboard/prescriptions",
  },
  {
    key: "investigations",
    label: "sidebar.investigations",
    icon: "mdi:test-tube",
    to: "/dashboard/investigations",
  },
  {
    key: "staff",
    label: "sidebar.staff",
    icon: "mdi:doctor",
    to: "/dashboard/staff",
  },
  {
    key: "reports",
    label: "sidebar.reports",
    icon: "mdi:chart-bar",
    children: [
      {
        key: "reports-revenue",
        label: "sidebar.revenueReport",
        icon: "mdi:cash-multiple",
        to: "/dashboard/reports/revenue",
      },
      {
        key: "reports-visits",
        label: "sidebar.visitsReport",
        icon: "mdi:chart-line",
        to: "/dashboard/reports/visits",
      },
    ],
  },
  {
    key: "settings",
    label: "sidebar.settings",
    icon: "mdi:cog-outline",
    to: "/dashboard/settings",
  },
]);

// ── Helpers ────────────────────────────────────────────────────────────────────
const separatorIcon = computed(() =>
  locale.value === "ar" ? "mdi:chevron-left" : "mdi:chevron-right",
);

const checkMobile = () => {
  if (!import.meta.client) return;
  isMobile.value = window.innerWidth <= 991;
  if (!isMobile.value) mobileSidebarOpen.value = false;
};

const saveCollapsed = (val) => {
  desktopCollapsed.value = val;
  if (import.meta.client)
    localStorage.setItem("sidebarCollapsed", JSON.stringify(val));
};

onMounted(() => {
  checkMobile();
  window.addEventListener("resize", checkMobile);
  const saved = localStorage.getItem("sidebarCollapsed");
  if (saved !== null) desktopCollapsed.value = JSON.parse(saved);
});
onUnmounted(() => window.removeEventListener("resize", checkMobile));
</script>

