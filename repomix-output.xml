<file path="my-app/main.js">
import { app, BrowserWindow, ipcMain } from "electron";
import serve from "electron-serve";
import path from "path";
import { fileURLToPath } from "url";
import { createRequire } from "module";
import { registerClinicHandlers } from "./ipc/clinic.js";
import { getDb } from "./db/connection.js"; // ← add this
import { initSchema } from "./db/schema.js"; // ← static import is fine

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const require = createRequire(import.meta.url);

// Squirrel startup check (must be first)
(function () {
  if (require("electron-squirrel-startup")) return;
})();

// Windows squirrel events
if (process.platform === "win32") {
  const command = process.argv[1];
  if (command === "--squirrel-install" || command === "--squirrel-updated") {
    app.setLoginItemSettings({
      openAtLogin: true,
      path: path.join(path.dirname(process.execPath), "..", "Update.exe"),
      args: [
        "--processStart",
        `"${path.basename(process.execPath)}"`,
        "--process-start-args",
        '"--autostart"',
      ],
    });
  } else if (command === "--squirrel-uninstall") {
    app.setLoginItemSettings({ openAtLogin: false });
  }
}

const loadURL = serve({ directory: path.join(__dirname, "../.output/public") });

const createWindow = async () => {
  const mainWindow = new BrowserWindow({
    icon: path.join(__dirname, "../public/logo/logo.ico"),
    width: 1200,
    height: 800,
    webPreferences: {
      nodeIntegration: false,
      contextIsolation: true,
      sandbox: false,
      preload: path.join(__dirname, "preload.mjs"),
    },
  });

  await loadURL(mainWindow);
};

app.whenReady().then(async () => {
  const db = getDb(); // ← called here, after app is ready
  initSchema(db); // ← pass db
  registerClinicHandlers(db, ipcMain); // ← pass db + ipcMain
  await createWindow();
});

app.on("window-all-closed", () => {
  if (process.platform !== "darwin") app.quit();
});
</file>

