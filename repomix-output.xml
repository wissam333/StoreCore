    type: Array,
    default: () => [],
  },
  maxFileSizeMB: {
    type: Number,
    default: 5,
  },
});

const emit = defineEmits(["update:modelValue"]);
const { $toast } = useNuxtApp();
const { t } = useI18n();

const inputRefs = ref({});
