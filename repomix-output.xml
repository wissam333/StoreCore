const checkMobile = () => {
  isMobile.value = window.innerWidth < 768;
  if (!isMobile.value) isOpen.value = false;
};

onMounted(() => {
  checkMobile();
  window.addEventListener("resize", checkMobile);
});

onUnmounted(() => window.removeEventListener("resize", checkMobile));
</script>

