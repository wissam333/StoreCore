    width: 20px;
    height: 20px;
    border-width: 2px;
  }
  &.md .spinner {
    width: 30px;
    height: 30px;
    border-width: 3px;
  }
  &.lg .spinner {
    width: 40px;
    height: 40px;
    border-width: 4px;
  }
}

.spinner {
  border: 3px solid var(--border-color); // ← was #e9ecef
  border-top-color: var(--primary); // ← default follows theme
  border-radius: 50%;
  animation: spin 0.8s linear infinite;

  &.primary {
