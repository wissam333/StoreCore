<script setup>
import { computed, ref, onMounted } from "vue";

const { t, locale } = useI18n();
const { stats, getVisits, getAppointments, getPatients, getSettings } =
  useClinic();

// ── State ──────────────────────────────────────────────────────────────────────
const loadingStats = ref(true);
const loadingVisits = ref(true);
const loadingAppts = ref(true);
const loadingPatients = ref(true);
const refreshing = ref(false);

const statsData = ref({});
const todayVisits = ref([]);
const upcomingAppts = ref([]);
const recentPatients = ref([]);
const clinicName = ref("");

const today = ref(new Date().toISOString().slice(0, 10));

// ── Load ───────────────────────────────────────────────────────────────────────
const loadAll = async () => {
  const [s, v, a, p, cfg] = await Promise.all([
    stats(),
    getVisits({ dateFrom: today, dateTo: today, limit: 8 }),
    getAppointments({ dateFrom: today, status: "scheduled", limit: 6 }),
    getPatients({ limit: 8 }),
    getSettings(),
  ]);

  if (s.ok) statsData.value = s.data;
  if (v.ok) today.value = v.data;
  if (a.ok) upcomingAppts.value = a.data;
  if (p.ok) recentPatients.value = p.data;
  if (cfg.ok) clinicName.value = cfg.data?.clinic_name || "";

  loadingStats.value = false;
  loadingAppts.value = false;
  loadingVisits.value = false;
  loadingPatients.value = false;
};

onMounted(loadAll);

const refresh = async () => {
  refreshing.value = true;
  loadingStats.value = true;
  loadingAppts.value = true;
