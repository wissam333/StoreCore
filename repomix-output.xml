        LEFT JOIN patients p ON a.patient_id=p.id
        LEFT JOIN staff    s ON a.doctor_id=s.id
        WHERE ${where} ORDER BY a.appt_date ASC LIMIT ? OFFSET ?
      `,
          )
          .all(...params, limit, offset);
