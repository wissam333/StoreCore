<template>
  <div>
    <SharedUiHeaderPage
      :title="$t('sidebar.categories')"
      :subtitle="$t('categoriesSubtitle')"
      icon="mdi:tag-multiple-outline"
      show-back
      back-to="/dashboard/products"
      :is-rtl="locale === 'ar'"
