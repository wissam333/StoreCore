          <div v-else class="line-area">
            <svg :viewBox="`0 0 ${svgW} ${svgH}`" preserveAspectRatio="none" class="trend-svg">
              <!-- area fill -->
              <path :d="areaPath" class="trend-area" />
              <!-- line -->
              <path :d="linePath" class="trend-line" />
              <!-- dots -->
              <circle
                v-for="(pt, i) in points"
                :key="i"
                :cx="pt.x" :cy="pt.y" r="3.5"
