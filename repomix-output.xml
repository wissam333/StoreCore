};

const confirmDelete = async () => {
  isDeleting.value = true;
  try {
    const r = await deletePrescription(selectedItem.value.id);
    if (r.ok) { $toast.success(t("deleteSuccess")); showDeleteModal.value = false; fetchRecords(); }
