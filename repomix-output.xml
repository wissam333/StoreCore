          </template>
          <template #cell-fee="{ row }">
            <span :class="['fee-val', { unpaid: !row.paid }]">
              {{ row.fee?.toFixed(2) }}
              <Icon :name="row.paid ? 'mdi:check-circle' : 'mdi:clock-outline'" size="13" />
            </span>
