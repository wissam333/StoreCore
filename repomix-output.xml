            <div class="col-md-2">
              <Field name="fee" v-slot="{ field }">
                <SharedUiFormBaseInput v-bind="field" :model-value="field.value" @update:model-value="field.onChange"
                  :label="$t('fee')" type="number" :placeholder="'0.00'" icon-left="mdi:cash" />
              </Field>
