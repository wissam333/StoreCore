    align-items: center;
    justify-content: center;
  }

  &.sm .circular-label {
    font-size: 0.75rem;
  }
  &.lg .circular-label {
    font-size: 1rem;
  }
}

// ══════════════════════════════════════════════
//  SPINNER
// ══════════════════════════════════════════════
.spinner-wrapper {
