        return value.toLocaleString();
      }
      return value;
    },
  },
});

const emit = defineEmits(["stat-click"]);

const trendIcon = (direction) => {
  return direction === "up" ? "mdi:trending-up" : "mdi:trending-down";
};

const formatValue = (stat) => {
  if (stat.formatter) {
