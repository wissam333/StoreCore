            variant="outline"
            @click="showDeleteModal = false"
          >
            {{ $t("cancel") }}
          </SharedUiButtonBase>
          <SharedUiButtonBase
            variant="error"
            :loading="deleting"
            @click="doDelete"
          >
            {{ $t("delete") }}
          </SharedUiButtonBase>
