        stroke: $color;
      }
    }
  }

  .circular-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary); // ← was #2c3e50
  }

  .circular-spinner {
