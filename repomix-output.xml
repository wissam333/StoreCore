        LEFT JOIN staff    s ON v.doctor_id=s.id
        WHERE v.id=? AND v._deleted=0
      `,
        )
        .get(id);
      if (!visit) return { ok: false, error: "Not found" };
      visit.prescriptions = db
        .prepare("SELECT * FROM prescriptions WHERE visit_id=? AND _deleted=0")
        .all(id);
      visit.investigations = db
        .prepare("SELECT * FROM investigations WHERE visit_id=? AND _deleted=0")
        .all(id);
      return { ok: true, data: visit };
